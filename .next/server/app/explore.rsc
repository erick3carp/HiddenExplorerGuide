2 hr"},{"id":3,"name":"Canal Street Historic District","slug":"canal-street-historic-district","city":"New Smyrna Beach","state":"FL","category":"Photo Spot","description":"Historic storefronts, murals, boutiques, and walkable details for relaxed street photography.","latitude":29.0252,"longitude":-80.9206,"featuredImage":"https://images.unsplash.com/photo-1519501025264-65ba15a82390?auto=format&fit=crop&w=1400&q=80","parking":"Free public lots and street parking nearby.","bestTime":"Late afternoon when storefronts catch warm light.","photoTip":"Capture detail shots of signs, windows, brick, and sidewalk texture.","duration":"1-2 hr"},{"id":4,"name":"Old Fort Park","slug":"old-fort-park","city":"New Smyrna Beach","state":"FL","category":"Park","description":"A quiet historic site near downtown with shaded paths and old stonework textures.","latitude":29.0258,"longitude":-80.919,"featuredImage":"https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1400&q=80","parking":"Street parking around the park.","bestTime":"Morning shade or golden hour.","photoTip":"Look for contrast between stone, moss, trees, and sky.","duration":"30-60 min"},{"id":5,"name":"Riverside Park","slug":"riverside-park","city":"New Smyrna Beach","state":"FL","category":"Family Activity","description":"A riverfront green space with playground areas, paths, events, and Indian River views.","latitude":29.0236,"longitude":-80.9182,"featuredImage":"https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1400&q=80","parking":"Free parking around Canal Street and Riverside Drive.","bestTime":"Sunset for river reflections.","photoTip":"Shoot low across the grass toward the water for layered compositions.","duration":"45-90 min"},{"id":6,"name":"Mary McLeod Bethune Beach Park","slug":"mary-mcleod-bethune-beach-park","city":"New Smyrna Beach","state":"FL","category":"Beach","description":"A quieter south beach access with oceanfront space and lagoon-side options nearby.","latitude":28.9418,"longitude":-80.8384,"featuredImage":"https://images.unsplash.com/photo-1471922694854-ff1b63b20054?auto=format&fit=crop&w=1400&q=80","parking":"Public parking with beach access.","bestTime":"Weekday mornings for a calmer visit.","photoTip":"Bring a longer lens for shorebirds and soft wave detail.","duration":"1-2 hr"},{"id":7,"name":"JB's Fish Camp","slug":"jbs-fish-camp","city":"New Smyrna Beach","state":"FL","category":"Restaurant","description":"A casual waterside seafood stop near the lagoon, popular after beach and kayak trips.","latitude":28.9336,"longitude":-80.8497,"featuredImage":"https://images.unsplash.com/photo-1533777857889-4be7c70b33f7?auto=format&fit=crop&w=1400&q=80","parking":"On-site restaurant parking.","bestTime":"Late lunch or sunset dinner.","photoTip":"Photograph dock details and plates near window light.","duration":"1-1.5 hr"},{"id":8,"name":"Indian River Lagoon Park","slug":"indian-river-lagoon-park","city":"New Smyrna Beach","state":"FL","category":"Nature","description":"A low-key park for lagoon views, short walks, birds, and slower coastal moments.","latitude":28.9905,"longitude":-80.8742,"featuredImage":"https://images.unsplash.com/photo-1495954484750-af469f2f9be5?auto=format&fit=crop&w=1400&q=80","parking":"Small on-site parking area.","bestTime":"Morning for wildlife and softer reflections.","photoTip":"Use reeds and mangroves to frame the water.","duration":"45-90 min"},{"id":9,"name":"The Garlic","slug":"the-garlic","city":"New Smyrna Beach","state":"FL","category":"Restaurant","description":"A lush, atmospheric dinner spot known for garden paths, low light, and date-night energy.","latitude":29.0432,"longitude":-80.9004,"featuredImage":"https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=1400&q=80","parking":"On-site and nearby parking, busiest at dinner.","bestTime":"Blue hour before peak dinner rush.","photoTip":"Capture warm lights through greenery before going inside.","duration":"1.5-2 hr"},{"id":10,"name":"Norwood's Treehouse","slug":"norwoods-treehouse","city":"New Smyrna Beach","state":"FL","category":"Restaurant","description":"A memorable restaurant setting with elevated seating, coastal character, and group-friendly energy.","latitude":29.0405,"longitude":-80.9007,"featuredImage":"https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?auto=format&fit=crop&w=1400&q=80","parking":"Restaurant parking available nearby.","bestTime":"Early dinner to catch ambient light.","photoTip":"Shoot vertical frames that show height, stairs, and greenery.","duration":"1.5-2 hr"},{"id":11,"name":"Third Wave Cafe","slug":"third-wave-cafe","city":"New Smyrna Beach","state":"FL","category":"Restaurant","description":"A cozy cafe and garden-style stop close to Flagler Avenue for brunch, coffee, and evening bites.","latitude":29.0399,"longitude":-80.9001,"featuredImage":"https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?auto=format&fit=crop&w=1400&q=80","parking":"Street parking around Flagler Avenue.","bestTime":"Brunch for bright table photos.","photoTip":"Use shaded patio light for food and portrait shots.","duration":"1 hr"},{"id":13,"name":"27th Avenue Beachfront Park","slug":"27th-avenue-beachfront-park","city":"New Smyrna Beach","state":"FL","category":"Family Activity","description":"Beach access with picnic areas, restrooms, and a practical setup for family beach time.","latitude":29.0107,"longitude":-80.8815,"featuredImage":"https://images.unsplash.com/photo-1519046904884-53103b34b206?auto=format&fit=crop&w=1400&q=80","parking":"Public parking lot by the beach.","bestTime":"Morning before the sand heats up.","photoTip":"Capture candid family moments from the dune crossover.","duration":"1-3 hr"},{"id":14,"name":"Esther Street Beachfront Park","slug":"esther-street-beachfront-park","city":"New Smyrna Beach","state":"FL","category":"Beach","description":"A central beach access close to Flagler Avenue with easy walks to food and shops.","latitude":29.0401,"longitude":-80.8965,"featuredImage":"https://images.unsplash.com/photo-1510414842594-a61c69b5ae57?auto=format&fit=crop&w=1400&q=80","parking":"Limited street parking and nearby paid options.","bestTime":"Sunrise and late afternoon.","photoTip":"Use footprints and tide patterns to add foreground interest.","duration":"45-120 min"},{"id":17,"name":"Buena Vista Park","slug":"buena-vista-park","city":"New Smyrna Beach","state":"FL","category":"Park","description":"A simple riverfront park with benches, boat activity, and a slower local rhythm.","latitude":29.033,"longitude":-80.9132,"featuredImage":"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1400&q=80","parking":"Small public parking areas nearby.","bestTime":"Golden hour facing the water.","photoTip":"Use benches and railings as foreground anchors.","duration":"30-60 min"},{"id":19,"name":"Sugar Mill Ruins","slug":"sugar-mill-ruins","city":"New Smyrna Beach","state":"FL","category":"Photo Spot","description":"Historic ruins wrapped in greenery, ideal for texture studies and moody natural-light photos.","latitude":29.0309,"longitude":-80.9711,"featuredImage":"https://images.unsplash.com/photo-1518005020951-eccb494ad742?auto=format&fit=crop&w=1400&q=80","parking":"Small free parking area.","bestTime":"Overcast afternoons or early light.","photoTip":"Expose for stone texture and let the background fall darker.","duration":"30-60 min"},{"id":20,"name":"Turtle Mound","slug":"turtle-mound","city":"New Smyrna Beach","state":"FL","category":"Nature","description":"A scenic mound walk south of town with sweeping lagoon and barrier island views.","latitude":28.9289,"longitude":-80.8242,"featuredImage":"https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1400&q=80","parking":"National seashore parking area; check current access rules.","bestTime":"Morning for lower heat and clearer views.","photoTip":"Shoot wide from the overlook to show the curve of the coast.","duration":"45-90 min"}]}]]}],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","explore","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/0ec96784a738c364.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","children":["$","body",null,{"className":"__className_f367f3","children":[["$","header",null,{"className":"sticky top-0 z-50 border-b border-ink/10 bg-shell/95 backdrop-blur","children":["$","nav",null,{"className":"mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8","children":[["$","$L5",null,{"href":"/","className":"flex items-center gap-2 font-semibold","children":[["$","span",null,{"className":"grid h-9 w-9 place-items-center rounded bg-coast text-sm font-bold text-white","children":"HE"}],["$","span",null,{"children":"Hidden Explorer Guide"}]]}],["$","div",null,{"className":"hidden items-center gap-1 sm:flex","children":[["$","$L5","/explore",{"href":"/explore","className":"rounded px-3 py-2 text-sm font-medium text-ink/70 transition hover:bg-white hover:text-ink","children":"Explore"}],["$","$L5","/destinations",{"href":"/destinations","className":"rounded px-3 py-2 text-sm font-medium text-ink/70 transition hover:bg-white hover:text-ink","children":"Destinations"}],["$","$L5","/map",{"href":"/map","className":"rounded px-3 py-2 text-sm font-medium text-ink/70 transition hover:bg-white hover:text-ink","children":"Map"}],["$","$L5","/about",{"href":"/about","className":"rounded px-3 py-2 text-sm font-medium text-ink/70 transition hover:bg-white hover:text-ink","children":"About"}]]}]]}]}],["$","$L3",null,{"parallelRouterKey":"children","segmentPath